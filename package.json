{
  "name": "assetvault-pro",
  "version": "0.5.0-alpha.2",
  "description": "AssetVault Pro - Professional Digital Asset Management System",
  "main": "./out/main/index.js",
  "author": "AssetVault Team",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm exec electron-vite dev",
    "build": "pnpm exec electron-vite build",
    "preview": "pnpm exec electron-vite preview",
    "postinstall": "node scripts/postinstall.mjs",
    "package": "pnpm exec electron-vite build && pnpm exec electron-builder --win",
    "package:mac": "pnpm exec electron-vite build && pnpm exec electron-builder --mac",
    "package:linux": "pnpm exec electron-vite build && pnpm exec electron-builder --linux",
    "lint": "pnpm exec eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "pnpm exec eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "typecheck": "pnpm exec tsc --noEmit",
    "i18n:check": "node scripts/check-i18n-keys.mjs",
    "theme:gen": "pnpm exec vitest run testing/gen/themeFallback.gen.test.ts",
    "test": "pnpm exec vitest run",
    "test:unit": "pnpm exec vitest run testing/unit testing/gen",
    "test:integration": "node scripts/run-vitest-integration.mjs",
    "test:integration:node": "pnpm exec vitest run --config vitest.integration.config.ts",
    "test:all": "pnpm test && pnpm run theme:gen && pnpm run openapi:check && pnpm run test:integration",
    "test:ci": "pnpm run theme:gen && pnpm test && pnpm run openapi:check",
    "test:watch": "pnpm exec vitest",
    "openapi:check": "node scripts/check-openapi-routes.mjs",
    "rebuild:native": "node scripts/rebuild-native.mjs",
    "fetch:ytdlp": "node scripts/fetch-ytdlp.mjs",
    "prepackage": "node scripts/fetch-ytdlp.mjs && node scripts/prepackage-clean.mjs",
    "db:generate": "pnpm exec drizzle-kit generate",
    "db:migrate": "pnpm exec drizzle-kit migrate",
    "db:studio": "pnpm exec drizzle-kit studio",
    "clean:install": "powershell -ExecutionPolicy Bypass -File scripts/clean-install.ps1",
    "preinstall": "node scripts/guard-package-manager.mjs"
  },
  "dependencies": {
    "@arco-design/web-react": "^2.63.0",
    "@babylonjs/core": "^9.7.0",
    "@babylonjs/loaders": "^9.7.0",
    "@napi-rs/canvas": "^1.0.0",
    "@napi-rs/image": "^1.12.0",
    "@tanstack/react-virtual": "^3.5.6",
    "@xyflow/react": "^12.10.2",
    "babylonjs-fbx-loader": "^1.1.0",
    "better-sqlite3": "^11.10.0",
    "chokidar": "^3.6.0",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.33.0",
    "exifreader": "^4.24.0",
    "exrs": "^1.0.3",
    "ffmpeg-static": "^5.2.0",
    "file-type": "^19.4.0",
    "fontkit": "^2.0.4",
    "framer-motion": "^11.9.0",
    "i18next": "^26.3.1",
    "lru-cache": "^10.4.3",
    "mime-types": "^2.1.35",
    "music-metadata": "^7.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.8",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.26.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^10.0.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mime-types": "^2.1.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.24.0",
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.12",
    "node-abi": "^3.74.0",
    "postcss": "^8.4.47",
    "prebuild-install": "^7.1.3",
    "prettier": "^3.3.2",
    "rcedit": "^4.0.1",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.assetvault.app",
    "productName": "AssetVault Pro",
    "icon": "resources/icon.ico",
    "afterPack": "scripts/after-pack.cjs",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "resources/icon.ico",
        "to": "app-icon.ico"
      },
      {
        "from": "resources/icon.png",
        "to": "app-icon.png"
      },
      {
        "from": "resources/better_sqlite3.node",
        "to": "better_sqlite3.node"
      },
      {
        "from": "doc/web-api-v1-openapi.yaml",
        "to": "web-api-v1-openapi.yaml"
      },
      {
        "from": "doc/web-api-v1-openapi.en.yaml",
        "to": "web-api-v1-openapi.en.yaml"
      },
      {
        "from": "resources/api-playground",
        "to": "api-playground"
      }
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/ffmpeg-static/**",
      "node_modules/@napi-rs/canvas/**",
      "node_modules/exrs/**",
      "node_modules/exrs-raw-wasm-bindgen/**"
    ],
    "files": [
      "out/**/*",
      "resources/**/*",
      "!resources/bin/*.zip",
      "node_modules/better-sqlite3/**/*",
      "node_modules/ffmpeg-static/**/*",
      "node_modules/@napi-rs/canvas/**/*",
      "node_modules/exrs/**/*",
      "node_modules/exrs-raw-wasm-bindgen/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico",
      "sign": false,
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "extraResources": [
        {
          "from": "resources/bin/yt-dlp.exe",
          "to": "bin/yt-dlp.exe"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "resources/bin/yt-dlp",
          "to": "bin/yt-dlp"
        }
      ]
    },
    "linux": {
      "extraResources": [
        {
          "from": "resources/bin/yt-dlp",
          "to": "bin/yt-dlp"
        }
      ]
    }
  },
  "packageManager": "pnpm@9.12.3",
  "overrides": {
    "babylonjs-fbx-loader": {
      "@babylonjs/core": "^9.7.0",
      "@babylonjs/loaders": "^9.7.0"
    }
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@babylonjs/core": "9",
        "@babylonjs/loaders": "9",
        "@babylonjs/materials": "9"
      }
    }
  }
}
